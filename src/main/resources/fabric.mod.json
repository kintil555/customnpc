{
  "schemaVersion": 1,
  "id": "npcmod",
  "version": "${version}",
  "name": "NPC Player Mod",
  "description": "Adds fully customizable static NPC Player entities with pose controls, equipment, and skin loading.",
  "authors": [{ "name": "NPCPlayerMod" }],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.npcmod.NpcMod"],
    "client": ["com.npcmod.NpcModClient"]
  },
  "mixins": ["npcmod.mixins.json"],
  "depends": {
    "fabricloader": ">=0.16.9",
    "minecraft": "~1.21.4",
    "java": ">=21",
    "fabric-api": "*"
  }
}